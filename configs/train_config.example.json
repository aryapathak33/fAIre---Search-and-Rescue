{
  "project": "fAIre",
  "model": "mobilenet_v2",
  "framework": "pytorch",
  "data_root": "data",
  "image_size": 224,
  "epochs": 10,
  "batch_size": 16,
  "learning_rate": 0.001,
  "augmentation": [
    "horizontal_flip",
    "color_jitter",
    "small_rotation"
  ],
  "objective": "recall_first_search_and_rescue",
  "positive_class_hint": "distress"
}